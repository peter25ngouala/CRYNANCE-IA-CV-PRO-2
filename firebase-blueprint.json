{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "premium", "admin"] },
        "isPremium": { "type": "boolean" },
        "cvGenerationsRemaining": { "type": "integer" },
        "letterGenerationsRemaining": { "type": "integer" },
        "analysisGenerationsRemaining": { "type": "integer" },
        "hasLetterAccess": { "type": "boolean" },
        "hasAnalysisAccess": { "type": "boolean" },
        "flashAtsExpiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "CV": {
      "title": "CV",
      "description": "Generated CV data",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner's UID" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "CV content in JSON or Markdown" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    },
    "PaymentRequest": {
      "title": "Payment Request",
      "description": "User payment requests for premium access",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/cvs/{cvId}": {
      "schema": "CV",
      "description": "Generated CVs"
    },
    "/payments/{requestId}": {
      "schema": "PaymentRequest",
      "description": "Payment verification requests"
    },
    "/promo_codes/{promoId}": {
      "schema": "object",
      "description": "Discount codes"
    },
    "/messages/{messageId}": {
      "schema": "object",
      "description": "Admin messages to users"
    }
  }
}
